# Lark Suite Email Configuration for Minova Solutions
# Copy this to .env.local and update with your actual credentials

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Configuration (SMTP) - Lark Suite
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@minova.vn
SMTP_PASSWORD=your_lark_suite_app_password
SMTP_FROM_EMAIL=info@minova.vn
SMTP_FROM_NAME=Minova Solutions
ADMIN_EMAIL=du.vu@minova.vn

# Mailchimp Configuration
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_AUDIENCE_ID=your_audience_id

# Instructions:
# 1. Go to Lark Suite Admin Console > Email & Calendar
# 2. Enable SMTP for the info@minova.vn account
# 3. Generate an app-specific password
# 4. Replace 'your_lark_suite_app_password' with the generated password
# 5. Test email sending functionality